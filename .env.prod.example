# Usuário/organização do GitHub (minúsculas) — dono das imagens ghcr.io/<isso>/passarela-{api,web}
GHCR_OWNER=troque-pelo-seu-usuario-github

# Domínios (DuckDNS ou domínio próprio) que o Caddy vai servir com HTTPS automático
FRONTEND_DOMAIN=passarela.duckdns.org
API_DOMAIN=passarela-api.duckdns.org

# Credenciais do usuário root do MongoDB — mesmas regras do backend/.env.example (senha forte, 15+ caracteres, exclusiva de produção)
MONGO_ROOT_USER=troque-pelo-usuario
MONGO_ROOT_PASSWORD=troque-por-uma-senha-forte-de-15-caracteres-ou-mais

# --- Variáveis específicas do container "api" (mesmas chaves de backend/.env.example) ---
NODE_ENV=production
PORT=3000
MONGODB_URI=mongodb://troque-pelo-usuario:troque-por-uma-senha-forte-de-15-caracteres-ou-mais@mongo:27017/passarela?authSource=admin
CORS_ORIGIN=https://passarela.duckdns.org
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
JWT_SECRET=troque-por-um-segredo-aleatorio-de-32-caracteres-ou-mais
JWT_EXPIRES_IN=1h
